# Empty = same-origin through CloudFront. Call sites already include "api/" in the path.
VITE_APP_URI=
# WebSocket endpoint — set to CloudFront domain at deploy time via CI
# VITE_WS_ENDPOINT=wss://your-cf-domain.cloudfront.net/ws
# Cognito — injected by CI from Terraform outputs
# VITE_COGNITO_USER_POOL_ID=us-west-2_XXXXXXXXX
# VITE_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
